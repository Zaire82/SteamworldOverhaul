<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="PlantBase">
		<defName>Plant_Starbloom</defName>
		<label>star bloom</label>
		<description>A plant with luminescent star-shaped flowers. They are very beautiful and can be used to produce certain chemicals.</description>
		<statBases>
			<MaxHitPoints>25</MaxHitPoints>
			<Beauty>25</Beauty>
			<Nutrition>0.2</Nutrition>
			<Flammability>0.75</Flammability>
		</statBases>
		<graphicData>
			<texPath>Things/Plants/Starbloom/Starbloom</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<altitudeLayer>Item</altitudeLayer>
		<selectable>true</selectable>
		<pathCost>10</pathCost>
		<plant>
			<growDays>10</growDays>
			<dieIfLeafless>true</dieIfLeafless>
			<harvestTag>Standard</harvestTag>
			<harvestedThingDef>SWO_Starbloom</harvestedThingDef>
			<immatureGraphicPath>Things/Plants/Starbloom/Starbloom_Immature</immatureGraphicPath>
			<harvestYield>3</harvestYield>
			<sowTags>
				<li>Ground</li>
				<li>Decorative</li>
				<li>Hydroponic</li>
			</sowTags>
			<sowMinSkill>8</sowMinSkill>
			<sowResearchPrerequisites>
				<li>BasicChemistry</li>
			</sowResearchPrerequisites>
			<topWindExposure>0.1</topWindExposure>
			<visualSizeRange>0.45~1</visualSizeRange>
			<fertilitySensitivity>0.8</fertilitySensitivity>
		</plant>
		<comps>
			<li Class="CompProperties_Glower">
				<glowRadius>3</glowRadius>
				<glowColor>(250,218,142,1)</glowColor>
			</li>
		</comps>
	</ThingDef>
	
</Defs>