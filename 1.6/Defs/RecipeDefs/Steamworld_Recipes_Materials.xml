<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <RecipeDef>
        <defName>RefineCopper</defName>
        <label>refine copper</label>
        <description>Smelt copper ore into pure copper.</description>
        <jobString>Smelting copper.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Smelt</effectWorking>
        <soundWorking>Recipe_Smelt</soundWorking>
        <workAmount>1000</workAmount>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>SWO_CopperOre</li>
                    </thingDefs>
                </filter>
                <count>10</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>SWO_CopperOre</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <SWO_Copper>10</SWO_Copper>
        </products>
        <workSkill>Crafting</workSkill>
        <displayPriority>0</displayPriority>
    </RecipeDef>

