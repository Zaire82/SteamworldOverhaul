<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <RecipeDef>
        <defName>Make_Gear</defName>
        <label>make gear</label>
        <description>Cut brass into a gear.</description>
        <jobString>Cutting Gears.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <workAmount>3000</workAmount>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>SWO_Brass</li>
                    </thingDefs>
                </filter>
                <count>5</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>SWO_Brass</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <SWO_Gear>1</SWO_Gear>
        </products>
        <researchPrerequisite>EarlyMachining</researchPrerequisite>
        <skillRequirements>
            <Crafting>6</Crafting>
        </skillRequirements>
        <workSkill>Crafting</workSkill>
        <displayPriority>0</displayPriority>
    </RecipeDef>

    <RecipeDef>
        <defName>Make_Spring</defName>
        <label>make spring</label>
        <description>Cut brass into a spring.</description>
        <jobString>Cutting Springs.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Cook</effectWorking>
        <soundWorking>Recipe_Machining</soundWorking>
        <workAmount>3000</workAmount>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>SWO_Brass</li>
                    </thingDefs>
                </filter>
                <count>8</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>SWO_Brass</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <SWO_Spring>1</SWO_Spring>
        </products>
        <researchPrerequisite>EarlyMachining</researchPrerequisite>
        <skillRequirements>
            <Crafting>6</Crafting>
        </skillRequirements>
        <workSkill>Crafting</workSkill>
        <displayPriority>0</displayPriority>
    </RecipeDef>

    <RecipeDef>
        <defName>Make_TreatedLeather</defName>
        <label>make treated leather</label>
        <description>Treat leather to make it more durable and sanitary.</description>
        <jobString>Treating leather.</jobString>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <effectWorking>Tailor</effectWorking>
        <soundWorking>Recipe_Tailor</soundWorking>
        <workAmount>1000</workAmount>
        <allowMixingIngredients>true</allowMixingIngredients>
        <recipeUsers>
            <li>ElectricTailoringBench</li>
            <li>HandTailoringBench</li>
        </recipeUsers>
        <ingredients>
            <li>
                <filter>
                <categories>
                    <li>Leathers</li>
                </categories>
                <disallowedThingDefs>
                    <li>Leather_Thrumbo</li>
                    <li MayRequire="Ludeon.RimWorld.Odyssey">Leather_AlphaThrumbo</li>
                </disallowedThingDefs>
                </filter>
                <count>20</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <categories>
                <li>Leathers</li>
            </categories>
            <disallowedThingDefs>
                <li>Leather_Patch</li>
                <li>Leather_Human</li>
                <li>SWO_TreatedLeather</li>
            </disallowedThingDefs>
        </fixedIngredientFilter>
        <products>
            <SWO_TreatedLeather>20</SWO_TreatedLeather>
        </products>
        <researchPrerequisite>LeatherTreating</researchPrerequisite>
        <skillRequirements>
            <Crafting>4</Crafting>
        </skillRequirements>
        <workSkill>Crafting</workSkill>
        <displayPriority>0</displayPriority>
    </RecipeDef>

</Defs>