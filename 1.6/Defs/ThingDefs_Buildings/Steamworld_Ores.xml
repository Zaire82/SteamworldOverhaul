<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!--============================ Resource rocks ===============================-->

    <ThingDef ParentName="RockBase">
        <defName>SWO_MineableCopper</defName>
        <label>copper ore</label>
        <description>Rock containing unrefined copper ore.</description>
        <graphicData>
            <texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
            <color>(183,115,51)</color>
            <colorTwo>(120,201,223)</colorTwo>
        </graphicData>
        <statBases>
            <MaxHitPoints>1500</MaxHitPoints>
        </statBases>
        <building>
            <isResourceRock>true</isResourceRock>
            <mineableThing>SWO_CopperOre</mineableThing>
            <mineableYield>40</mineableYield>
            <mineableScatterCommonality>1</mineableScatterCommonality>
            <mineableScatterLumpSizeRange>10~20</mineableScatterLumpSizeRange>
            <veinMineable>true</veinMineable>
        </building>
    </ThingDef>

