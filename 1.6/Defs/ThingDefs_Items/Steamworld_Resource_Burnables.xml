<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <ThingDef ParentName="ResourceBase">
        <defName>SWO_Coal</defName>
        <label>coal</label>
        <description>A black rock that can be burned to produce higher temperatures than wood and can be refined into chemfuel.</description>
        <graphicData>
            <texPath>Things/Item/Resource/SWO_Coal</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <soundInteract>ChunkRock_Drop</soundInteract>
        <soundDrop>ChunkRock_Drop</soundDrop>
        <statBases>
            <MaxHitPoints>150</MaxHitPoints>
            <MarketValue>1.5</MarketValue>
            <Mass>0.4</Mass>
            <Flammability>1.5</Flammability>
        </statBases>
        <useHitPoints>true</useHitPoints>
        <healthAffectsPrice>false</healthAffectsPrice>
        <thingCategories>
            <li>ResourcesRaw</li>
        </thingCategories>
        <deepCommonality>4</deepCommonality>
        <deepCountPerPortion>45</deepCountPerPortion>
        <deepLumpSizeRange>8~16</deepLumpSizeRange>
        <stuffProps>
            <categories>
                <li>Stony</li>
            </categories>
            <commonality>0.05</commonality>
            <constructEffect>ConstructMetal</constructEffect>
            <isAirtight>false</isAirtight>
            <color>(54,53,51)</color>
            <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
            <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
            <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
            <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
            <statFactors>
                <MaxHitPoints>0.5</MaxHitPoints>
                <Beauty>0.6</Beauty>
                <Flammability>1.5</Flammability>
            </statFactors>
        </stuffProps>
        <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
        <allowedArchonexusCount>100</allowedArchonexusCount>
    </ThingDef>

    <ThingDef ParentName="ResourceBase">
        <defName>SWO_Coke</defName>
        <label>coke</label>
        <description>A high carbon content variant of coal produced by heating it in a no-oxygen environment. It burns hotter than other coal and can be used in a blast furnace.</description>
        <graphicData>
            <texPath>Things/Item/Resource/SWO_Coke</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <soundInteract>ChunkRock_Drop</soundInteract>
        <soundDrop>ChunkRock_Drop</soundDrop>
        <statBases>
            <MaxHitPoints>200</MaxHitPoints>
            <MarketValue>1.8</MarketValue>
            <Mass>0.4</Mass>
            <Flammability>2</Flammability>
        </statBases>
        <useHitPoints>true</useHitPoints>
        <healthAffectsPrice>false</healthAffectsPrice>
        <thingCategories>
            <li>ResourcesRaw</li>
        </thingCategories>
        <allowedArchonexusCount>100</allowedArchonexusCount>
    </ThingDef>

</Defs>