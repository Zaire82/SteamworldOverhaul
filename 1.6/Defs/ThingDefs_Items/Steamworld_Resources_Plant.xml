<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="ResourceBase">
		<defName>SWO_Starbloom</defName>
		<label>starbloom</label>
		<description>Luminescent flowers that resembles the shape of a star. It can be used to produce certain chemicals.</description>
		<graphicData>
			<texPath>Things/Item/Resource/Plant/Starbloom_harvest</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>1</drawSize>
		</graphicData>
		<soundInteract>Metal_Drop</soundInteract>
		<soundDrop>Standard_Drop</soundDrop>
		<stackLimit>50</stackLimit>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<MarketValue>2.3</MarketValue>
			<Mass>0.05</Mass>
			<Flammability>1</Flammability>
			<DeteriorationRate>2.0</DeteriorationRate>
		</statBases>
		<healthAffectsPrice>false</healthAffectsPrice>
		<thingCategories>
			<li>PlantMatter</li>
		</thingCategories>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="CompProperties_Rottable">
				<daysToRotStart>30</daysToRotStart>
				<rotDestroys>true</rotDestroys>
			</li>
		</comps>
		<allowedArchonexusCount>80</allowedArchonexusCount>
	</ThingDef>

