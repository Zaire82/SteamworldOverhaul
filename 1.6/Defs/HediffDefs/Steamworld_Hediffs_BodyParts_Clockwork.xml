<?xml version="1.0" encoding="utf-8" ?>
<Defs>

    <!-- Clockwork Part bases (Medieval tech) -->

    <HediffDef Name="ClockworkBodyPartBase" ParentName="AddedBodyPartBase" Abstract="True">
        <defaultLabelColor>(181, 141, 60)</defaultLabelColor>
    </HediffDef>

    <ThingDef Name="BodyPartClockworkBase" ParentName="BodyPartBase" Abstract="True">
        <techLevel>Medieval</techLevel>
        <thingCategories>
            <li>BodyPartsProsthetic</li>
        </thingCategories>
        <graphicData>
            <texPath>Things/Item/Manufactured/LeatherChest</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>1</drawSize>
            <color>(255,255,255)</color>
        </graphicData>
        <statBases>
            <WorkToMake>12000</WorkToMake>
        </statBases>
        <recipeMaker>
            <displayPriority>600</displayPriority>
        </recipeMaker>
    </ThingDef>

    <ThingDef Name="BodyPartClockworkLimbMakeableBase" ParentName="BodyPartClockworkBase" Abstract="True">
        <recipeMaker>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Smith</soundWorking>
        <recipeUsers>
            <li>SteamMachiningTable</li>
        </recipeUsers>
            <skillRequirements>
                <Crafting>5</Crafting>
            </skillRequirements>
            <unfinishedThingDef>UnfinishedHealthItemProsthetic</unfinishedThingDef>
            <researchPrerequisite>ClockworkLimbs</researchPrerequisite>
        </recipeMaker>
    </ThingDef>

    <ThingDef Name="BodyPartClockworkOrganMakeableBase" ParentName="BodyPartClockworkBase" Abstract="True">
        <recipeMaker>
        <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
        <workSkill>Crafting</workSkill>
        <effectWorking>Smith</effectWorking>
        <soundWorking>Recipe_Smith</soundWorking>
        <recipeUsers>
            <li>SteamMachiningTable</li>
        </recipeUsers>
            <skillRequirements>
                <Crafting>6</Crafting>
            </skillRequirements>
            <unfinishedThingDef>UnfinishedHealthItemProsthetic</unfinishedThingDef>
            <researchPrerequisite>ClockworkOrgans</researchPrerequisite>
        </recipeMaker>
    </ThingDef>

    <RecipeDef Name="SurgeryInstallBodyPartClockworkBase" ParentName="SurgeryInstallBodyPartArtificialBase" Abstract="True">
        <skillRequirements>
            <Medicine>4</Medicine>
        </skillRequirements>
    </RecipeDef>

  <!-- Clockwork Arm -->

  <HediffDef ParentName="ClockworkBodyPartBase">
    <defName>SWO_ClockworkArm</defName>
    <label>clockwork arm</label>
    <labelNoun>a clockwork arm</labelNoun>
    <description>An installed clockwork arm. While it lacks a neural interface, its complex arrangement of clockwork mechanisms allows it to mimic natural movement quite convincingly. Still, it is inferior to a real arm.</description>
    <descriptionHyperlinks><ThingDef>SWO_ClockworkArm</ThingDef></descriptionHyperlinks>
    <comps>
      <li Class="HediffCompProperties_VerbGiver">
        <tools>
          <li>
            <label>fist</label>
            <capacities>
              <li>Blunt</li>
            </capacities>
            <power>8.2</power> <!-- Same as natural fist -->
            <cooldownTime>2</cooldownTime>
          </li>
        </tools>
      </li>
    </comps>
    <spawnThingOnRemoved>SWO_ClockworkArm</spawnThingOnRemoved>
    <addedPartProps>
      <solid>true</solid>
      <partEfficiency>0.70</partEfficiency>
    </addedPartProps>
  </HediffDef>

  <ThingDef ParentName="BodyPartClockworkLimbMakeableBase">
    <defName>SWO_ClockworkArm</defName>
    <label>clockwork arm</label>
    <description>A clockwork arm prosthesis. While it lacks a neural interface, its complex arrangement of clockwork mechanisms allows it to mimic natural movement quite convincingly. Still, it is inferior to a real arm.</description>
    <descriptionHyperlinks><RecipeDef>Install_SWO_ClockworkArm</RecipeDef></descriptionHyperlinks>
    <costList>
      <SWO_Gear>10</SWO_Gear>
      <SWO_Spring>5</SWO_Spring>
      <SWO_Brass>20</SWO_Brass>
    </costList>
    <statBases>
      <Mass>5</Mass>
    </statBases>
    <techHediffsTags>
      <li>Simple</li>
    </techHediffsTags>
  </ThingDef>

  <RecipeDef ParentName="SurgeryInstallBodyPartClockworkBase">
    <defName>Install_SWO_ClockworkArm</defName>
    <label>install clockwork arm</label>
    <description>Install a clockwork arm.</description>
    <descriptionHyperlinks>
      <ThingDef>SWO_ClockworkArm</ThingDef>
      <HediffDef>SWO_ClockworkArm</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing clockwork arm.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>SWO_ClockworkArm</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>SWO_ClockworkArm</li>
      </thingDefs>
    </fixedIngredientFilter>
    <appliedOnFixedBodyParts>
      <li>Shoulder</li>
    </appliedOnFixedBodyParts>
    <addsHediff>SWO_ClockworkArm</addsHediff>
  </RecipeDef>

